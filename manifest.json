{
    "manifest_version": 2,
    "name": "Firefox Phishing Detector",
    "version": "0.1.0",
    "description": "Detect potentially suspicios phishing websites using local heuristics.",

    "permissions": [
        "tabs",
        "activeTab",
        "storage"
    ],

    "background": {
        "scripts": [
            "background.js"
        ],
        "type": "module"
    },

    "browser_action": {
        "default_title": "Phishing Detector",
        "default_popup": "popup/popup.html"
    },

    "icons": {
        "48": "icons/icon48.png"
    }
}